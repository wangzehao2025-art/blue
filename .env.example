# ============================================================
# BlueOcean 选品系统 - 环境变量示例
# ============================================================
# 复制此文件为 .env 并填入你自己的 API Keys
# ⚠️ .env 文件已在 .gitignore 中,不会被提交到 Git

# === DeepSeek (AI 顾问主推理,国内可用,推荐) ===
# 注册: https://platform.deepseek.com
# 充值 ¥10 可用几个月
DEEPSEEK_API_KEY=sk-xxx

# === 智谱 GLM (国内联网检索,可选) ===
# 注册: https://open.bigmodel.cn
# 新用户送 2500 万 Tokens
ZHIPU_API_KEY=xxx.xxx

# === Perplexity (国外联网检索,需翻墙+外币卡,可选) ===
# 注册: https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-xxx

# === Cloudflare Worker 代理 (解决 CORS,可选) ===
# 部署方法见 worker.js
WORKER_URL=https://your-worker.workers.dev
WORKER_TOKEN=your_random_token_here
